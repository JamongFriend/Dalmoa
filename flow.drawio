        <mxCell id="p4-rte1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p4-rt-req" target="p4-rt-cache" parent="p4-rt-g"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p4-rte2" value="HIT" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p4-rt-cache" target="p4-rt-hit" parent="p4-rt-g"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p4-rte3" value="MISS" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p4-rt-cache" target="p4-rt-miss" parent="p4-rt-g"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Scheduled group -->
        <mxCell id="p4-sch-g" value="DB 저장용 (ExchangeRateScheduler)" style="swimlane;startSize=25;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="p4-1">
