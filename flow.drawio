  <diagram id="page4" name="4. 알림 &amp; 환율 스케줄러">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="p4-0"/>
        <mxCell id="p4-1" parent="p4-0"/>

        <!-- NOTIFICATION SCHEDULER -->
        <mxCell id="p4-t1" value="알림 스케줄러" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=14;" vertex="1" parent="p4-1">
          <mxGeometry x="50" y="20" width="230" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p4-cron" value="⏰ 매일 오전 09:00&#xa;Cron: 0 0 9 * * *" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" vertex="1" parent="p4-1">
          <mxGeometry x="80" y="60" width="180" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="p4-check" value="checkAndSendNotifications()" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="p4-1">
          <mxGeometry x="85" y="135" width="170" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="p4-7d-q" value="오늘+7일 == 결제일인 구독 조회" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="p4-1">
          <mxGeometry x="65" y="200" width="210" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="p4-7d-n" value="알림 저장:&#xa;'일주일 뒤에 [서비스명] 결제 예정'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="p4-1">
          <mxGeometry x="65" y="260" width="210" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p4-1d-q" value="오늘+1일 == 결제일인 구독 조회" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="p4-1">
          <mxGeometry x="65" y="335" width="210" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="p4-1d-n" value="알림 저장:&#xa;'내일 [서비스명] 결제 예정. 잔액 확인!'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="p4-1">
          <mxGeometry x="65" y="395" width="210" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p4-sep" value="앱 실행 시 (Android)" style="text;html=1;strokeColor=none;fillColor=none;fontStyle=1;" vertex="1" parent="p4-1">
          <mxGeometry x="80" y="465" width="180" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="p4-unread" value="GET /api/notifications/unread-exists&#xa;읽지 않은 알림 여부 확인" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="p4-1">
          <mxGeometry x="50" y="500" width="240" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p4-list" value="GET /api/notifications&#xa;전체 알림 목록 (최신순)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="p4-1">
          <mxGeometry x="50" y="565" width="240" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p4-read" value="PATCH /api/notifications/{id}/read&#xa;읽음 처리" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="p4-1">
          <mxGeometry x="50" y="630" width="240" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="p4-ne1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p4-cron" target="p4-check" parent="p4-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p4-ne2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p4-check" target="p4-7d-q" parent="p4-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p4-ne3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p4-7d-q" target="p4-7d-n" parent="p4-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p4-ne4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p4-7d-n" target="p4-1d-q" parent="p4-1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="p4-ne5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="p4-1d-q" target="p4-1d-n" parent="p4-1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- EXCHANGE RATE -->
        <mxCell id="p4-t2" value="환율 이중 구조" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=14;" vertex="1" parent="p4-1">
          <mxGeometry x="400" y="20" width="260" height="30" as="geometry"/>
        </mxCell>

        <!-- Realtime group -->
        <mxCell id="p4-rt-g" value="실시간 계산용 (CalculationService)" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="p4-1">
          <mxGeometry x="370" y="60" width="300" height="255" as="geometry"/>
