# MySQL 전용 변수 (DB 초기 생성용)
MYSQL_DATABASE=dalmoa
MYSQL_USER=dalmoa
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here

# Spring Boot 전용 변수 (앱 연결용)
DB_URL=jdbc:mysql://dalmoa-db:3306/dalmoa?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=dalmoa
DB_PASSWORD=your_mysql_password_here

# Security & APIs
JWT_SECRET=your_jwt_secret_minimum_32_characters_here
EXCHANGE_API_KEY=your_exchange_api_key_here
